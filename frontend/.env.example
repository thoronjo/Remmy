# Copy this file to .env and fill in your real values
# Never commit real keys or secrets

VITE_API_URL=http://localhost:3001
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Use an exact URL that exists in Supabase Auth > URL Configuration > Redirect URLs
# Example (dev): http://localhost:5173
# Example (prod): https://your-production-domain.com
VITE_AUTH_REDIRECT_URL=http://localhost:5173

# Comma-separated exact redirect allow-list used by the app before OAuth starts
VITE_AUTH_REDIRECT_ALLOWLIST=http://localhost:5173,https://your-production-domain.com
